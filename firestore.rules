rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isValidTransaction() {
      return request.resource.data.keys().hasAll(['type', 'amount', 'date', 'categoryId', 'userId'])
        && request.resource.data.type in ['income', 'expense']
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
    }

    function isValidCategory() {
      return request.resource.data.keys().hasAll(['name', 'icon', 'type', 'userId'])
        && request.resource.data.type in ['income', 'expense', 'both'];
    }

    match /transactions/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid && isValidTransaction();
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /categories/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid && isValidCategory();
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
